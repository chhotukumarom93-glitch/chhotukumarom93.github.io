<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Photo Tools Pro</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">

<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-XH3TGNG491P"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-XH3TGNG491P');
</script>

<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXX"
     crossorigin="anonymous"></script>

</head>
<body>

<!-- Top Ad -->
<div class="top-ad">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXX"
         data-ad-slot="1111111111"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>
         (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
</div>

    <div class="container">

        <!-- Header -->
        <div class="header">
            <h1>📸 Photo Tools Pro</h1>
            <p>Compress • Passport • Signature • PDF • BG Remove • Thumbnail</p>
        </div>

        <!-- Card -->
        <div class="card">

            <!-- Result Messages -->
            {% if result %}
                {% if result.success %}
                    <div class="success-box">{{ result.success }}</div>
                {% endif %}
                {% if result.error %}
                    <div class="error-box">{{ result.error }}</div>
                {% endif %}
            {% endif %}

            <!-- Form -->
            <form method="POST" enctype="multipart/form-data">

                <!-- Tool Select -->
                <label for="toolSelect">Select Tool</label>
                <select name="tool" id="toolSelect" onchange="toggleFields()">
                    <option value="compress" {% if selected_tool == "compress" %}selected{% endif %}>Image Compressor</option>
                    <option value="passport" {% if selected_tool == "passport" %}selected{% endif %}>Passport Photo Maker</option>
                    <option value="signature" {% if selected_tool == "signature" %}selected{% endif %}>Signature Resize</option>
                    <option value="formphoto" {% if selected_tool == "formphoto" %}selected{% endif %}>Form Photo Resize</option>
                    <option value="bgremove" {% if selected_tool == "bgremove" %}selected{% endif %}>Background Remover</option>
                    <option value="pdf" {% if selected_tool == "pdf" %}selected{% endif %}>Image to PDF</option>
                    <option value="thumbnail" {% if selected_tool == "thumbnail" %}selected{% endif %}>Thumbnail Tool</option>
                </select>

                <!-- Single Upload -->
                <div id="singleImageBox">
                    <label>Upload Image</label>
                    <input type="file" name="image">
                </div>

                <!-- Multiple Upload -->
                <div id="multiImageBox" style="display:none;">
                    <label>Upload Multiple Images (for PDF)</label>
                    <input type="file" name="images" multiple>
                </div>

                <!-- Target Size -->
                <div id="targetSizeBox">
                    <label>Target Size (KB)</label>
                    <input type="number" name="target_kb" placeholder="e.g. 100">
                </div>

                <!-- Width -->
                <div id="widthBox">
                    <label>Width (optional)</label>
                    <input type="number" name="width" placeholder="e.g. 800">
                </div>

                <!-- Height -->
                <div id="heightBox">
                    <label>Height (optional)</label>
                    <input type="number" name="height" placeholder="e.g. 600">
                </div>

                <!-- Output Format -->
                <div id="formatBox">
                    <label>Output Format</label>
                    <select name="format">
                        <option value="JPG">JPG</option>
                        <option value="PNG">PNG</option>
                        <option value="WEBP">WEBP</option>
                    </select>
                </div>

                <button type="submit">🚀 Process Now</button>
            </form>

           <!-- Download -->
{% if result and result.download_file %}
<div class="download-section">
    <a class="download-btn" href="{{ url_for('download_file', folder='outputs', filename=result.download_file) }}">
        ⬇ Download Result
    </a>
</div>
{% endif %}

<!-- Preview -->
{% if result and result.preview_file %}
<div class="preview-section">
    <h3>Preview</h3>
    <img class="preview-img" src="{{ url_for('static', filename=result.preview_folder + '/' + result.preview_file) }}" alt="Preview">
</div>
{% endif %}

        </div>

<!-- Middle Ad -->
<div class="middle-ad">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXX"
         data-ad-slot="2222222222"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>
         (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
</div>

        <!-- Footer -->
        <div class="footer">
            © 2026 Photo Tools Pro | All Rights Reserved
        </div>
    </div>

<!-- Bottom Ad -->
<div class="bottom-ad">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-XXXXXXXXXXXXXXX"
         data-ad-slot="3333333333"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>
         (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
</div>

    <script>
        function toggleFields() {
            let tool = document.getElementById("toolSelect").value;

            let singleImageBox = document.getElementById("singleImageBox");
            let multiImageBox = document.getElementById("multiImageBox");
            let targetSizeBox = document.getElementById("targetSizeBox");
            let widthBox = document.getElementById("widthBox");
            let heightBox = document.getElementById("heightBox");
            let formatBox = document.getElementById("formatBox");

            // Default
            singleImageBox.style.display = "block";
            multiImageBox.style.display = "none";
            targetSizeBox.style.display = "block";
            widthBox.style.display = "block";
            heightBox.style.display = "block";
            formatBox.style.display = "block";

            // BG Remove
            if (tool === "bgremove") {
                targetSizeBox.style.display = "none";
                widthBox.style.display = "none";
                heightBox.style.display = "none";
                formatBox.style.display = "none";
            }

            // PDF
            if (tool === "pdf") {
                singleImageBox.style.display = "none";
                multiImageBox.style.display = "block";
                targetSizeBox.style.display = "none";
                widthBox.style.display = "none";
                heightBox.style.display = "none";
                formatBox.style.display = "none";
            }

            // Other resize tools
            if (tool === "passport" || tool === "signature" || tool === "formphoto" || tool === "thumbnail") {
                targetSizeBox.style.display = "none";
            }
        }

        window.onload = toggleFields;

<div style="text-align:center; margin:20px 0;">
    <p style="font-size:18px; font-weight:bold; color:#222;">
        👁 Total Visitors: {{ visitor_count }}
    </p>
</div>

    </script>
<footer class="site-footer">
    <div>
        <a href="/privacy">Privacy Policy</a>
        <a href="/about">About Us</a>
        <a href="/contact">Contact Us</a>
    </div>
    <p>© 2026 Photo Tools Pro | All Rights Reserved</p>
</footer>

</body>
</html>
